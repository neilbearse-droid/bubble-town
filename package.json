{
  "name": "tiny-town",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Tiny Town — a cozy Toca Boca-style paper-doll sandbox game.",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "test": "node scripts/check-data.mjs && node scripts/smoke.mjs",
    "ios": "npm run build && cap sync ios && cap open ios",
    "ios:sync": "npm run build && cap sync ios",
    "ios:assets": "capacitor-assets generate --ios"
  },
  "dependencies": {
    "@capacitor/app": "^8.1.0",
    "@capacitor/core": "^8.4.0",
    "@capacitor/ios": "^8.4.0",
    "@capacitor/preferences": "^8.0.1",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@supabase/supabase-js": "^2.108.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^8.4.0",
    "@eslint/js": "^9.39.4",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.16",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.26",
    "globals": "^15.15.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.4.32",
    "sharp": "^0.35.1",
    "tailwindcss": "^3.4.1",
    "vite": "^5.0.10",
    "vite-plugin-pwa": "^1.3.0"
  }
}
